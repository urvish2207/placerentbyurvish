# ============================================================
# .dockerignore - Exclude unnecessary files from Docker build
# ============================================================

# Version control
.git
.gitignore
.gitattributes

# Development environments
.env
.env.backup
.env.example
.env.local
.env.development
.editorconfig
.idea
.vscode
.fleet
.nova
.zed
.phpunit.cache
.phpunit.result.cache

# Documentation
README.md
aicodebrdige.md
Homestead.json
Homestead.yaml

# Tests
tests
phpunit.xml

# Node.js (we pre-build assets)
node_modules

# Logs
*.log
storage/logs/*

# Laravel framework cache (will be regenerated)
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Database dumps (security)
database/*.sql
database/*.sqlite
database/database.sqlite

# Deployment configs (not needed inside container)
railway-deploy.js
