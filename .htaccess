<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /placeRent01/

    # 1. Block access to sensitive system files
    RedirectMatch 403 /\.(git|env|gitignore|gitattributes|editorconfig)$
    RedirectMatch 403 /(composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|phpunit\.xml|vite\.config\.js|tailwind.config.js|postcss.config.js)$

    # 2. Block access to internal directories
    RedirectMatch 403 /app/
    RedirectMatch 403 /bootstrap/
    RedirectMatch 403 /config/
    RedirectMatch 403 /database/
    RedirectMatch 403 /resources/
    RedirectMatch 403 /routes/
    RedirectMatch 403 /storage/
    RedirectMatch 403 /tests/
    RedirectMatch 403 /vendor/

    # 3. Redirect root requests to public/ folder
    RewriteRule ^$ public/ [R=301,L]
    RewriteRule ^index\.php$ public/ [R=301,L]
</IfModule>
